<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZenosKeyboard" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/brand_primary</item>
        <item name="android:colorBackground">@color/brand_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/brand_primary</item>
    </style>

    <style name="Theme.ZenosKeyboard.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Key style -->
    <style name="KeyButton">
        <item name="android:layout_margin">2dp</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/key_bg</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="KeyButton.Special">
        <item name="android:background">@drawable/key_special_bg</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/brand_accent</item>
    </style>

    <style name="KeyButton.Termux">
        <item name="android:background">@drawable/key_termux_bg</item>
        <item name="android:textColor">@color/termux_key_text</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="KeyButton.Action">
        <item name="android:background">@drawable/key_action_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
