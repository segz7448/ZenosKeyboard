<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Text Shortcuts"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_add_shortcut"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Add"
            android:textSize="13sp"
            android:backgroundTint="@color/brand_accent"
            android:textColor="@color/brand_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>

    <!-- Add form (hidden by default) -->
    <LinearLayout
        android:id="@+id/add_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/input_keyword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/shortcut_keyword_hint"
            android:textColor="@color/white"
            android:textColorHint="@color/on_surface_variant"
            android:backgroundTint="@color/brand_accent"
            android:inputType="text"
            android:paddingBottom="4dp"/>

        <EditText
            android:id="@+id/input_expansion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/shortcut_expansion_hint"
            android:textColor="@color/white"
            android:textColorHint="@color/on_surface_variant"
            android:backgroundTint="@color/brand_accent"
            android:inputType="textMultiLine"
            android:layout_marginTop="8dp"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_save_shortcut"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Save"
                android:backgroundTint="@color/brand_accent"
                android:textColor="@color/brand_primary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_cancel_shortcut"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:backgroundTint="@color/surface"
                android:textColor="@color/on_surface_variant"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/shortcuts_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:id="@+id/shortcuts_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/empty_shortcuts"
        android:gravity="center"
        android:textColor="@color/on_surface_variant"
        android:visibility="gone"/>
</LinearLayout>
