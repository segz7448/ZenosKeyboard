<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZenosKeyboard">

        <!-- IME Service -->
        <service
            android:name=".ime.ZenosIME"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod"/>
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/ime_config"/>
        </service>

        <!-- Clipboard Monitor Service -->
        <service
            android:name=".clipboard.ClipboardService"
            android:exported="false"/>

        <!-- Setup / Launcher Activity -->
        <activity
            android:name=".admin.SetupActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ZenosKeyboard">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Admin Activity -->
        <activity
            android:name=".admin.AdminActivity"
            android:exported="false"
            android:label="@string/admin_label"
            android:parentActivityName=".admin.SetupActivity"/>

    </application>

</manifest>
