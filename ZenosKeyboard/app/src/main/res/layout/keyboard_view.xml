<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg"
    android:paddingBottom="4dp">

    <!-- Suggestion / Clipboard strip -->
    <HorizontalScrollView
        android:id="@+id/suggestion_scroll"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/suggestion_bg"
        android:scrollbars="none"
        android:fadingEdge="horizontal"
        android:requiresFadingEdge="horizontal">

        <LinearLayout
            android:id="@+id/suggestion_bar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </HorizontalScrollView>

    <!-- Termux Row -->
    <LinearLayout
        android:id="@+id/termux_row"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@color/termux_row_bg"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <Button
            android:id="@+id/key_ctrl_c"
            style="@style/KeyButton.Termux"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ctrl+C\n(Kill)"/>

        <Button
            android:id="@+id/key_ctrl_z"
            style="@style/KeyButton.Termux"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ctrl+Z\n(Susp)"/>

        <Button
            android:id="@+id/key_ctrl_d"
            style="@style/KeyButton.Termux"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ctrl+D\n(EOF)"/>

        <Button
            android:id="@+id/key_ctrl_l"
            style="@style/KeyButton.Termux"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ctrl+L\n(Clear)"/>

        <Button
            android:id="@+id/key_tab"
            style="@style/KeyButton.Termux"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Tab\n(Auto)"/>
    </LinearLayout>

    <!-- Row 1: Numbers -->
    <LinearLayout
        android:id="@+id/row_numbers"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"/>

    <!-- Row 2: QWERTY top -->
    <LinearLayout
        android:id="@+id/row_qwerty1"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"/>

    <!-- Row 3: QWERTY middle -->
    <LinearLayout
        android:id="@+id/row_qwerty2"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"/>

    <!-- Row 4: QWERTY bottom -->
    <LinearLayout
        android:id="@+id/row_qwerty3"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"/>

    <!-- Row 5: Action row (Shift, Space, Enter etc) -->
    <LinearLayout
        android:id="@+id/row_action"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"/>

</LinearLayout>
