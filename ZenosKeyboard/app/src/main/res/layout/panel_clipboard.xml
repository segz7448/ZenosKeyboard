<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:orientation="vertical"
    android:background="@color/keyboard_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/brand_primary"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Clipboard History"
            android:textColor="@color/brand_accent"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_clear_clipboard"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Clear"
            android:textSize="11sp"
            android:textColor="@color/error"
            android:background="@color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

        <Button
            android:id="@+id/btn_close_clipboard"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:background="@color/transparent"
            android:padding="0dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/clipboard_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/clipboard_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/empty_clipboard"
        android:gravity="center"
        android:textColor="@color/on_surface_variant"
        android:textSize="13sp"
        android:visibility="gone"/>
</LinearLayout>
